@model List<TaskManagerWeb.Models.TaskItem>
@{
    var selectedDate =
        DateTime.Today;
}

@{
    var total = Model.Count;

    var completed = Model.Count(t => t.Completed);

    var percentage = total == 0
        ? 0
        : (completed * 100) / total;
}

<div class="main-container">

    <div class="hero">

        <h1>Stay Locked In.</h1>

        <p>
            Organize your chaos.
            Build momentum.
            Stay dangerous.
        </p>

    </div>

    <div class="stats-grid">

        <div class="stat-card glass-card">

            <h2>@Model.Count</h2>

            <p>Total Tasks</p>

        </div>

        <div class="stat-card glass-card">

            <h2>@Model.Count(t => t.Completed)</h2>

            <p>Completed</p>

        </div>

        <div class="stat-card glass-card">

            <h2>@Model.Count(t => !t.Completed)</h2>

            <p>Pending</p>

        </div>

    </div>

    <div class="progress-section glass-card">

        <div class="progress-header">

            <h2>Momentum</h2>

            <span>@percentage%</span>

        </div>

        <div class="progress-bar">

            <div class="progress-fill"
                 style="width:@percentage%">

            </div>

        </div>

    </div>

    <form method="post"
          asp-action="Add"
          class="task-form glass-card">

        <input type="text"
               name="Title"
               placeholder="What are we building today?"
               required />

        <select name="Priority">

            <option value="High">High Priority</option>
            <option value="Medium">Medium Priority</option>
            <option value="Low">Low Priority</option>

        </select>

        <input type="date"
       name="DueDate" />
        <button type="submit">
            Add Task
        </button>

    </form>

    <div class="dashboard-layout">

        <!-- LEFT PANEL -->

        <div class="left-panel">

            <div class="task-grid">

                @if(!Model.Any())
                {
                    <div class="glass-card empty-state">

                        <h2>No tasks yet.</h2>

                        <p>
                            Lock in and start building something.
                        </p>

                    </div>
                }

                @for(int i = 0; i < Model.Count; i++)
                {
                    var task = Model[i];

                    var priorityClass =
                        task.Priority.ToString().ToLower();

                    <div class="task-card glass-card priority-@priorityClass"
                         style="animation-delay:@(i * 0.1)s">

                        <div>

                            <h3>@task.Title</h3>

                            <p>
                                Priority:
                                <strong>@task.Priority</strong>
                            </p>

                            <p>
                                Due:
                                @task.DueDate.ToString("dd MMM yyyy")
                            </p>

                            <div class="status @(task.Completed ? "completed" : "pending")">

                                @(task.Completed ? "Completed" : "Pending")

                            </div>

                        </div>

                        <div class="actions">

                            <a asp-action="Complete"
                               asp-route-id="@task.Id"
                               class="complete-btn">

                                Complete

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@task.Id"
                               class="delete-btn">

                                Delete

                            </a>

                        </div>

                    </div>
                }

            </div>

        </div>

        <!-- RIGHT PANEL -->

        <div class="right-panel">

            <!-- CALENDAR -->

            <div class="calendar-widget glass-card">

                <div class="calendar-header">

                    <h2>May 2026</h2>

                    <div class="calendar-nav">

                        <span>◀</span>
                        <span>▶</span>

                    </div>

                </div>

                <div class="calendar-days">

                    <span>S</span>
                    <span>M</span>
                    <span>T</span>
                    <span>W</span>
                    <span>T</span>
                    <span>F</span>
                    <span>S</span>

                </div>

                <div class="calendar-grid">

@for(int day = 1; day <= 31; day++)
{
    var current =
        new DateTime(2026,5,day);

    var hasTask =
        Model.Any(t =>
            t.DueDate.Date == current.Date);

    <span class="
        @(day == DateTime.Today.Day ? "active-day" : "")
        @(hasTask ? "task-day" : "")
    ">

        @day

    </span>
}

</div>
            <!-- FOCUS PANEL -->

            <div class="focus-widget glass-card">

                <h2>Focus Session</h2>

                <p>Deep Work Mode</p>

                <div class="focus-time">
                    02:14:36
                </div>

                <button class="focus-btn">

                    Resume Session

                </button>

            </div>

        </div>

    </div>

</div>